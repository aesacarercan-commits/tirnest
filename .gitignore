```gitignore
# Dependencies
node_modules/

# Build outputs
dist/
build/
*.js.map
*.ts.map

# Environment variables
.env
.env.local
*.env.*

# Logs
*.log

# Coverage reports
coverage/
htmlcov/
*.coverage

# IDE files
.vscode/
.idea/
*.swp
*.swo
*.tmp

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.so
.coverage

# Compiled and binary files
*.exe
*.dll
*.so
*.a
*.o
*.obj
*.out

# Compressed files
*.zip
*.gz
*.tar
*.tgz
*.bz2
*.xz
*.7z
*.rar
*.zst
*.lz4
*.lzh
*.cab
*.arj
*.rpm
*.deb
*.Z
*.lz
*.lzo

# System files
.DS_Store
Thumbs.db
```